@prefix : <http://semantics.id/ns/example/film#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://semantics.id/ns/example/film#> .

<http://semantics.id/ns/example/film> rdf:type owl:Ontology ;
                                       owl:versionIRI <http://semantics.id/ns/example/film/1.0.0> ;
                                       <http://purl.org/dc/terms/contributor> "Filip Kovacevic" ,
                                                                              "Laura Waltersdorfer" ,
                                                                              "Marta Sabou" ;
                                       <http://purl.org/dc/terms/created> "2022-09-30" ;
                                       <http://purl.org/dc/terms/creator> "Fajar J. Ekaputra" ;
                                       <http://purl.org/dc/terms/description> "An ontology about film and related concepts developed for ISS course at TU Wien. Extended to include Streaming Platforms, Subscriptions, and Awards." ;
                                       <http://purl.org/dc/terms/title> "The Extended Streaming Film Ontology" .

#################################################################
#    Annotation properties
#################################################################

<http://purl.org/dc/terms/contributor> rdf:type owl:AnnotationProperty .
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .
owl:minCardinality rdf:type owl:AnnotationProperty .

#################################################################
#    Datatypes
#################################################################

xsd:date rdf:type rdfs:Datatype .

#################################################################
#    Object Properties
#################################################################

### Base Properties
:friendOf rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/knows> ;
          rdf:type owl:SymmetricProperty ;
          rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
          rdfs:range <http://xmlns.com/foaf/0.1/Person> ;
          rdfs:label "friendOf" .

:hasActor rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :hasPerformer ;
          rdfs:domain :Film ;
          rdfs:range :Actor ;
          rdfs:label "hasActor" ;
          owl:minCardinality 1 .

:hasComposer rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasCrew ;
             rdfs:domain :Film ;
             rdfs:range :Composer ;
             rdfs:label "hasComposer" .

:hasCrew rdf:type owl:ObjectProperty ;
         rdfs:domain :Film ;
         rdfs:range <http://xmlns.com/foaf/0.1/Person> ;
         rdfs:label "hasCrew" .

:hasDirector rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasCrew ;
             rdfs:domain :Film ;
             rdfs:range :Director ;
             rdfs:label "hasDirector" ;
             owl:minCardinality 1 .

:hasFilmStudio rdf:type owl:ObjectProperty ;
               rdfs:domain :Film ;
               rdfs:range :FilmStudio ;
               rdfs:label "hasFilmStudio" ;
               owl:minCardinality 1 .

:hasGenre rdf:type owl:ObjectProperty ;
          rdfs:domain :Film ;
          rdfs:range :Genre ;
          rdfs:label "hasGenre" ;
          owl:minCardinality 1 .

:hasPerformer rdf:type owl:ObjectProperty ;
              rdfs:domain :Artwork ;
              rdfs:range :Performer ;
              rdfs:label "hasPerformer" .

:hasScriptWriter rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :hasCrew ;
                 rdfs:domain :Film ;
                 rdfs:range :ScriptWriter ;
                 rdfs:label "hasScriptWriter" ;
                 owl:minCardinality 1 .

:hasSoundtrack rdf:type owl:ObjectProperty ;
               rdfs:domain :Film ;
               rdfs:range :Soundtrack ;
               rdfs:label "hasSoundtrack" .

# 1. Functional (Replacing the old hasAgeRating)
:hasAgeRating rdf:type owl:ObjectProperty , 
                       owl:FunctionalProperty ; 
              rdfs:domain :Artwork ; 
              rdfs:range :AgeRating ; 
              rdfs:label "hasAgeRating" .

# 2. Inverse Functional
:wroteReview rdf:type owl:ObjectProperty , 
                      owl:InverseFunctionalProperty ; 
             rdfs:domain :Subscriber ; 
             rdfs:range :Review ; 
             rdfs:label "wroteReview" .

# 3. Symmetric
:coStarredWith rdf:type owl:ObjectProperty , 
                        owl:SymmetricProperty ; 
               rdfs:domain :Actor ; 
               rdfs:range :Actor ; 
               rdfs:label "coStarredWith" .

# 4. Asymmetric
:nextEpisode rdf:type owl:ObjectProperty , 
                      owl:AsymmetricProperty ; 
             rdfs:domain :Episode ; 
             rdfs:range :Episode ; 
             rdfs:label "nextEpisode" .

# 5. Reflexive
:inSameUniverse rdf:type owl:ObjectProperty , 
                         owl:ReflexiveProperty ; 
                rdfs:domain :Artwork ; 
                rdfs:range :Artwork ; 
                rdfs:label "inSameUniverse" .

# 6. Irreflexive
:recommendsTo rdf:type owl:ObjectProperty , 
                       owl:IrreflexiveProperty ; 
              rdfs:domain :Subscriber ; 
              rdfs:range :Subscriber ; 
              rdfs:label "recommendsTo" .

# Note: :sequel (Transitive) is already defined natively in the TU Wien base code.

:prequel rdf:type owl:ObjectProperty ;
         owl:inverseOf :sequel ;
         rdf:type owl:TransitiveProperty ;
         rdfs:domain :Film ;
         rdfs:range :Film ;
         rdfs:label "prequel" .

:sequel rdf:type owl:ObjectProperty ,
                 owl:TransitiveProperty ;
        rdfs:domain :Film ;
        rdfs:range :Film ;
        rdfs:label "sequel" .


# Done a health-check and added missing properties and relations:
### --- STRUCTURAL CLEANUP: MISSING OBJECT PROPERTIES --- ###

# 1. Patching the Crew Disconnect
:hasProducer rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasCrew ;
             rdfs:domain :Film ;
             rdfs:range :Producer ;
             rdfs:label "hasProducer" .

:hasCinematographer rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :hasCrew ;
                    rdfs:domain :Film ;
                    rdfs:range :Cinematographer ;
                    rdfs:label "hasCinematographer" .

:hasEditor rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :hasCrew ;
           rdfs:domain :Film ;
           rdfs:range :Editor ;
           rdfs:label "hasEditor" .

:hasCostumeDesigner rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :hasCrew ;
                    rdfs:domain :Film ;
                    rdfs:range :CostumeDesigner ;
                    rdfs:label "hasCostumeDesigner" .

# 2. Patching the Review Disconnect
:reviewsArtwork rdf:type owl:ObjectProperty ;
                rdfs:domain :Review ;
                rdfs:range :Artwork ;
                rdfs:label "reviewsArtwork" .

# 3. Patching the Season Disconnect
:hasSeason rdf:type owl:ObjectProperty ;
           rdfs:domain :Series ;
           rdfs:range :Season ;
           rdfs:label "hasSeason" .

:hasEpisode rdf:type owl:ObjectProperty ;
            rdfs:domain :Season ;
            rdfs:range :Episode ;
            rdfs:label "hasEpisode" .

# 4. Patching the Country Disconnect
:availableInCountry rdf:type owl:ObjectProperty ;
                    rdfs:domain :StreamingPlatform ;
                    rdfs:range :Country ;
                    rdfs:label "availableInCountry" .

:hasOriginCountry rdf:type owl:ObjectProperty ;
                  rdfs:domain :Artwork ;
                  rdfs:range :Country ;
                  rdfs:label "hasOriginCountry" .

# (Making locatedIn Functional as discussed)
:locatedIn rdf:type owl:ObjectProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Subscriber ;
           rdfs:range :Country ;
           rdfs:label "locatedIn" .

<http://xmlns.com/foaf/0.1/knows> rdf:type owl:ObjectProperty ;
                                  rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
                                  rdfs:range <http://xmlns.com/foaf/0.1/Person> .

### Extension Properties (Streaming & Awards)
:watched rdf:type owl:ObjectProperty ; rdfs:domain :Subscriber ; rdfs:range :Artwork ; rdfs:label "watched" .
:likes rdf:type owl:ObjectProperty ; rdfs:domain :Subscriber ; rdfs:range :Artwork ; rdfs:label "likes" .
:availableOn rdf:type owl:ObjectProperty ; rdfs:domain :Artwork ; rdfs:range :StreamingPlatform ; rdfs:label "availableOn" .
:belongsToSeries rdf:type owl:ObjectProperty ; rdfs:domain :Episode ; rdfs:range :Series ; rdfs:label "belongsToSeries" .
:hasPlan rdf:type owl:ObjectProperty ; rdfs:domain :Subscriber ; rdfs:range :SubscriptionPlan ; rdfs:label "hasPlan" .
:subscribedTo rdf:type owl:ObjectProperty ; rdfs:domain :Subscriber ; rdfs:range :StreamingPlatform ; rdfs:label "subscribedTo" .
:hasAgeRating rdf:type owl:ObjectProperty ; rdfs:domain :Artwork ; rdfs:range :AgeRating ; rdfs:label "hasAgeRating" .
:hasAward rdf:type owl:ObjectProperty ; rdfs:domain :Artwork ; rdfs:range :Award ; rdfs:label "hasAward" .

#################################################################
#    Data properties
#################################################################

### Base Data Properties
:budget rdf:type owl:DatatypeProperty ;
        rdfs:domain :Film ;
        rdfs:range xsd:float ;
        rdfs:label "budget" .

:dateOfBirth rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
             rdfs:range xsd:date ;
             rdfs:label "dateOfBirth" .

:duration rdf:type owl:DatatypeProperty ;
          rdfs:domain :Artwork ;
          rdfs:range xsd:float ;
          rdfs:label "duration" .

:establishedDate rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :FilmStudio ;
                 rdfs:range xsd:date ;
                 rdfs:label "establishedDate" .

:fullName rdf:type owl:DatatypeProperty ;
          rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
          rdfs:range xsd:string ;
          rdfs:label "fullName" .

:gender rdf:type owl:DatatypeProperty ,
                 owl:FunctionalProperty ;
        rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
        rdfs:range xsd:string ;
        rdfs:label "gender" .

:releaseYear rdf:type owl:DatatypeProperty ;
             rdfs:domain :Film ;
             rdfs:range xsd:integer ;
             rdfs:label "releaseYear" .

### Extension Data Properties (To reach 10 total)
:subscriberAge rdf:type owl:DatatypeProperty ;
               rdfs:domain :Subscriber ;
               rdfs:range xsd:integer ;
               rdfs:label "subscriberAge" .

:imdbRating rdf:type owl:DatatypeProperty ;
            rdfs:domain :Artwork ;
            rdfs:range xsd:decimal ;
            rdfs:label "imdbRating" .

:subscriptionCost rdf:type owl:DatatypeProperty ;
                  rdfs:domain :SubscriptionPlan ;
                  rdfs:range xsd:decimal ;
                  rdfs:label "subscriptionCost" .

### Final 10 Extension Data Properties (To reach exactly 20)
:episodeNumber rdf:type owl:DatatypeProperty ;
               rdfs:domain :Episode ;
               rdfs:range xsd:integer ;
               rdfs:label "episodeNumber" .

:seasonNumber rdf:type owl:DatatypeProperty ;
              rdfs:domain :Season ;
              rdfs:range xsd:integer ;
              rdfs:label "seasonNumber" .

:synopsis rdf:type owl:DatatypeProperty ;
          rdfs:domain :Artwork ;
          rdfs:range xsd:string ;
          rdfs:label "synopsis" .

:originalLanguage rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Artwork ;
                  rdfs:range xsd:string ;
                  rdfs:label "originalLanguage" .

:maxSimultaneousStreams rdf:type owl:DatatypeProperty ;
                        rdfs:domain :SubscriptionPlan ;
                        rdfs:range xsd:integer ;
                        rdfs:label "maxSimultaneousStreams" .

:platformURL rdf:type owl:DatatypeProperty ;
             rdfs:domain :StreamingPlatform ;
             rdfs:range xsd:string ;
             rdfs:label "platformURL" .

:hasAds rdf:type owl:DatatypeProperty ;
        rdfs:domain :SubscriptionPlan ;
        rdfs:range xsd:boolean ;
        rdfs:label "hasAds" .

:registrationDate rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Subscriber ;
                  rdfs:range xsd:date ;
                  rdfs:label "registrationDate" .

:awardYear rdf:type owl:DatatypeProperty ;
           rdfs:domain :Award ;
           rdfs:range xsd:integer ;
           rdfs:label "awardYear" .

:reviewScore rdf:type owl:DatatypeProperty ;
             rdfs:domain :Review ;
             rdfs:range xsd:integer ;
             rdfs:label "reviewScore" .

#################################################################
#    Classes (40 Total)
#################################################################

### Base Classes (11)
:Actor rdf:type owl:Class ; rdfs:subClassOf :Performer , <http://xmlns.com/foaf/0.1/Person> ; rdfs:label "Actor" .
:Artwork rdf:type owl:Class ; rdfs:label "Artwork" .
:Composer rdf:type owl:Class ; rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ; rdfs:label "Composer" .
:Director rdf:type owl:Class ; rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ; rdfs:label "Director" .
:Film rdf:type owl:Class ; rdfs:subClassOf :Artwork ; rdfs:label "Film" .
:FilmStudio rdf:type owl:Class ; rdfs:label "FilmStudio" .
:Genre rdf:type owl:Class ; rdfs:label "Genre" .
:Performer rdf:type owl:Class ; rdfs:label "Performer" .
:ScriptWriter rdf:type owl:Class ; rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ; rdfs:label "ScriptWriter" .
:Soundtrack rdf:type owl:Class ; rdfs:subClassOf :Artwork ; rdfs:label "Soundtrack" .
<http://xmlns.com/foaf/0.1/Person> rdf:type owl:Class .

### Extended Content Classes
:ShortFilm rdf:type owl:Class ; rdfs:subClassOf :Film ; rdfs:label "ShortFilm" .
:Series rdf:type owl:Class ; rdfs:subClassOf :Artwork ; rdfs:label "Series" .
:Miniseries rdf:type owl:Class ; rdfs:subClassOf :Series ; rdfs:label "Miniseries" .
:Season rdf:type owl:Class ; rdfs:subClassOf :Artwork ; rdfs:label "Season" .
:Episode rdf:type owl:Class ; rdfs:subClassOf :Artwork ; rdfs:label "Episode" .
:Trailer rdf:type owl:Class ; rdfs:subClassOf :Artwork ; rdfs:label "Trailer" .
:AgeRating rdf:type owl:Class ; rdfs:label "AgeRating" .

### Extended Crew & User Classes
:Producer rdf:type owl:Class ; rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ; rdfs:label "Producer" .
:Cinematographer rdf:type owl:Class ; rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ; rdfs:label "Cinematographer" .
:Editor rdf:type owl:Class ; rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ; rdfs:label "Editor" .
:CostumeDesigner rdf:type owl:Class ; rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ; rdfs:label "CostumeDesigner" .
:VoiceActor rdf:type owl:Class ; rdfs:subClassOf :Actor ; rdfs:label "VoiceActor" .
:Subscriber rdf:type owl:Class ; rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ; rdfs:label "Subscriber" .

### Extended Platform & Business Classes
:StreamingPlatform rdf:type owl:Class ; rdfs:label "StreamingPlatform" .
:SubscriptionPlan rdf:type owl:Class ; rdfs:label "SubscriptionPlan" .
:BasicPlan rdf:type owl:Class ; rdfs:subClassOf :SubscriptionPlan ; rdfs:label "BasicPlan" .
:PremiumPlan rdf:type owl:Class ; rdfs:subClassOf :SubscriptionPlan ; rdfs:label "PremiumPlan" .
:FamilyPlan rdf:type owl:Class ; rdfs:subClassOf :SubscriptionPlan ; rdfs:label "FamilyPlan" .
:AdSupportedPlan rdf:type owl:Class ; rdfs:subClassOf :SubscriptionPlan ; rdfs:label "AdSupportedPlan" .
:StudentPlan rdf:type owl:Class ; rdfs:subClassOf :SubscriptionPlan ; rdfs:label "StudentPlan" .
:Country rdf:type owl:Class ; rdfs:label "Country" .
:Review rdf:type owl:Class ; rdfs:label "Review" .

### Extended Award Classes
:Award rdf:type owl:Class ; rdfs:label "Award" .
:Oscar rdf:type owl:Class ; rdfs:subClassOf :Award ; rdfs:label "Oscar" .
:Emmy rdf:type owl:Class ; rdfs:subClassOf :Award ; rdfs:label "Emmy" .
:BestComedy rdf:type owl:Class ; rdfs:subClassOf :Emmy ; rdfs:label "BestComedy" .
:BestDrama rdf:type owl:Class ; rdfs:subClassOf :Emmy ; rdfs:label "BestDrama" .
:GoldenGlobe rdf:type owl:Class ; rdfs:subClassOf :Award ; rdfs:label "GoldenGlobe" .
:PalmeDOr rdf:type owl:Class ; rdfs:subClassOf :Award ; rdfs:label "PalmeDOr" .

#################################################################
#    Individuals
#################################################################

