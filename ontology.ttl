@prefix : <http://semantics.id/ns/example/film#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://semantics.id/ns/example/film#> .

<http://semantics.id/ns/example/film> rdf:type owl:Ontology ;
                                       owl:versionIRI <http://semantics.id/ns/example/film/1.0.0> ;
                                       <http://purl.org/dc/terms/contributor> "Filip Kovacevic" ,
                                                                              "Laura Waltersdorfer" ,
                                                                              "Marta Sabou" ;
                                       <http://purl.org/dc/terms/created> "2022-09-30" ;
                                       <http://purl.org/dc/terms/creator> "Fajar J. Ekaputra" ;
                                       <http://purl.org/dc/terms/description> "An ontology about film and related concepts developed for ISS course at TU Wien. Extended to include Streaming Platforms, Subscriptions, and Awards." ;
                                       <http://purl.org/dc/terms/title> "The Extended Streaming Film Ontology" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/contributor
<http://purl.org/dc/terms/contributor> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#minCardinality
owl:minCardinality rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://semantics.id/ns/example/film#availableInCountry
:availableInCountry rdf:type owl:ObjectProperty ;
                    rdfs:domain :StreamingPlatform ;
                    rdfs:range :Country ;
                    rdfs:label "availableInCountry" .


###  http://semantics.id/ns/example/film#availableOn
:availableOn rdf:type owl:ObjectProperty ;
             rdfs:domain :Artwork ;
             rdfs:range :StreamingPlatform ;
             rdfs:label "availableOn" .


###  http://semantics.id/ns/example/film#belongsToSeries
:belongsToSeries rdf:type owl:ObjectProperty ;
                 rdfs:domain :Episode ;
                 rdfs:range :Series ;
                 rdfs:label "belongsToSeries" .


###  http://semantics.id/ns/example/film#coStarredWith
:coStarredWith rdf:type owl:ObjectProperty ,
                        owl:SymmetricProperty ;
               rdfs:domain :Actor ;
               rdfs:range :Actor ;
               rdfs:label "coStarredWith" .


###  http://semantics.id/ns/example/film#coWatched
:coWatched rdf:type owl:ObjectProperty ,
                    owl:SymmetricProperty ;
           rdfs:domain :Subscriber ;
           rdfs:range :Subscriber ;
           rdfs:label "coWatched" .


###  http://semantics.id/ns/example/film#friendOf
:friendOf rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/knows> ;
          rdf:type owl:SymmetricProperty ;
          rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
          rdfs:range <http://xmlns.com/foaf/0.1/Person> ;
          rdfs:label "friendOf" .


###  http://semantics.id/ns/example/film#hasActor
:hasActor rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :hasPerformer ;
          rdfs:domain :Film ;
          rdfs:range :Actor ;
          rdfs:label "hasActor" ;
          owl:minCardinality 1 .


###  http://semantics.id/ns/example/film#hasAgeRating
:hasAgeRating rdf:type owl:ObjectProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :Artwork ;
              rdfs:range :AgeRating ;
              rdfs:label "hasAgeRating" .


###  http://semantics.id/ns/example/film#hasAward
:hasAward rdf:type owl:ObjectProperty ;
          rdfs:domain :Artwork ;
          rdfs:range :Award ;
          rdfs:label "hasAward" .


###  http://semantics.id/ns/example/film#hasCinematographer
:hasCinematographer rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :hasCrew ;
                    rdfs:domain :Film ;
                    rdfs:range :Cinematographer ;
                    rdfs:label "hasCinematographer" .


###  http://semantics.id/ns/example/film#hasComposer
:hasComposer rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasCrew ;
             rdfs:domain :Film ;
             rdfs:range :Composer ;
             rdfs:label "hasComposer" .


###  http://semantics.id/ns/example/film#hasCostumeDesigner
:hasCostumeDesigner rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :hasCrew ;
                    rdfs:domain :Film ;
                    rdfs:range :CostumeDesigner ;
                    rdfs:label "hasCostumeDesigner" .


###  http://semantics.id/ns/example/film#hasCrew
:hasCrew rdf:type owl:ObjectProperty ;
         rdfs:domain :Film ;
         rdfs:range <http://xmlns.com/foaf/0.1/Person> ;
         rdfs:label "hasCrew" .


###  http://semantics.id/ns/example/film#hasDirector
:hasDirector rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasCrew ;
             rdfs:domain :Film ;
             rdfs:range :Director ;
             rdfs:label "hasDirector" ;
             owl:minCardinality 1 .


###  http://semantics.id/ns/example/film#hasEditor
:hasEditor rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :hasCrew ;
           rdfs:domain :Film ;
           rdfs:range :Editor ;
           rdfs:label "hasEditor" .


###  http://semantics.id/ns/example/film#hasEpisode
:hasEpisode rdf:type owl:ObjectProperty ;
            rdfs:domain :Season ;
            rdfs:range :Episode ;
            rdfs:label "hasEpisode" .


###  http://semantics.id/ns/example/film#hasFilmStudio
:hasFilmStudio rdf:type owl:ObjectProperty ;
               rdfs:domain :Film ;
               rdfs:range :FilmStudio ;
               rdfs:label "hasFilmStudio" ;
               owl:minCardinality 1 .


###  http://semantics.id/ns/example/film#hasGenre
:hasGenre rdf:type owl:ObjectProperty ;
          rdfs:domain :Film ;
          rdfs:range :Genre ;
          rdfs:label "hasGenre" ;
          owl:minCardinality 1 .


###  http://semantics.id/ns/example/film#hasOriginCountry
:hasOriginCountry rdf:type owl:ObjectProperty ;
                  rdfs:domain :Artwork ;
                  rdfs:range :Country ;
                  rdfs:label "hasOriginCountry" .


###  http://semantics.id/ns/example/film#hasPerformer
:hasPerformer rdf:type owl:ObjectProperty ;
              rdfs:domain :Artwork ;
              rdfs:range :Performer ;
              rdfs:label "hasPerformer" .


###  http://semantics.id/ns/example/film#hasPlan
:hasPlan rdf:type owl:ObjectProperty ;
         rdfs:domain :Subscriber ;
         rdfs:range :SubscriptionPlan ;
         rdfs:label "hasPlan" .


###  http://semantics.id/ns/example/film#hasProducer
:hasProducer rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasCrew ;
             rdfs:domain :Film ;
             rdfs:range :Producer ;
             rdfs:label "hasProducer" .


###  http://semantics.id/ns/example/film#hasScriptWriter
:hasScriptWriter rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :hasCrew ;
                 rdfs:domain :Film ;
                 rdfs:range :ScriptWriter ;
                 rdfs:label "hasScriptWriter" ;
                 owl:minCardinality 1 .


###  http://semantics.id/ns/example/film#hasSeason
:hasSeason rdf:type owl:ObjectProperty ;
           rdfs:domain :Series ;
           rdfs:range :Season ;
           rdfs:label "hasSeason" .


###  http://semantics.id/ns/example/film#hasSoundtrack
:hasSoundtrack rdf:type owl:ObjectProperty ;
               rdfs:domain :Film ;
               rdfs:range :Soundtrack ;
               rdfs:label "hasSoundtrack" .


###  http://semantics.id/ns/example/film#inProgress
:inProgress rdf:type owl:ObjectProperty ;
            rdfs:domain :Subscriber ;
            rdfs:range :Episode ;
            rdfs:label "inProgress" .


###  http://semantics.id/ns/example/film#inSameUniverse
:inSameUniverse rdf:type owl:ObjectProperty ,
                         owl:ReflexiveProperty ;
                rdfs:domain :Artwork ;
                rdfs:range :Artwork ;
                rdfs:label "inSameUniverse" .


###  http://semantics.id/ns/example/film#likes
:likes rdf:type owl:ObjectProperty ;
       rdfs:domain :Subscriber ;
       rdfs:range :Artwork ;
       rdfs:label "likes" .


###  http://semantics.id/ns/example/film#locatedIn
:locatedIn rdf:type owl:ObjectProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Subscriber ;
           rdfs:range :Country ;
           rdfs:label "locatedIn" .


###  http://semantics.id/ns/example/film#nextEpisode
:nextEpisode rdf:type owl:ObjectProperty ,
                      owl:AsymmetricProperty ;
             rdfs:domain :Episode ;
             rdfs:range :Episode ;
             rdfs:label "nextEpisode" .


###  http://semantics.id/ns/example/film#offersPlan
:offersPlan rdf:type owl:ObjectProperty ;
            rdfs:domain :StreamingPlatform ;
            rdfs:range :SubscriptionPlan ;
            rdfs:label "offersPlan" .


###  http://semantics.id/ns/example/film#prequel
:prequel rdf:type owl:ObjectProperty ;
         owl:inverseOf :sequel ;
         rdf:type owl:TransitiveProperty ;
         rdfs:domain :Film ;
         rdfs:range :Film ;
         rdfs:label "prequel" .


###  http://semantics.id/ns/example/film#recommendsTo
:recommendsTo rdf:type owl:ObjectProperty ,
                       owl:IrreflexiveProperty ;
              rdfs:domain :Subscriber ;
              rdfs:range :Subscriber ;
              rdfs:label "recommendsTo" .


###  http://semantics.id/ns/example/film#reviewsArtwork
:reviewsArtwork rdf:type owl:ObjectProperty ;
                rdfs:domain :Review ;
                rdfs:range :Artwork ;
                rdfs:label "reviewsArtwork" .


###  http://semantics.id/ns/example/film#sequel
:sequel rdf:type owl:ObjectProperty ,
                 owl:TransitiveProperty ;
        rdfs:domain :Film ;
        rdfs:range :Film ;
        rdfs:label "sequel" .


###  http://semantics.id/ns/example/film#subscribedTo
:subscribedTo rdf:type owl:ObjectProperty ;
              rdfs:domain :Subscriber ;
              rdfs:range :StreamingPlatform ;
              rdfs:label "subscribedTo" .


###  http://semantics.id/ns/example/film#watched
:watched rdf:type owl:ObjectProperty ;
         rdfs:domain :Subscriber ;
         rdfs:range :Artwork ;
         rdfs:label "watched" .


###  http://semantics.id/ns/example/film#wroteReview
:wroteReview rdf:type owl:ObjectProperty ,
                      owl:InverseFunctionalProperty ;
             rdfs:domain :Subscriber ;
             rdfs:range :Review ;
             rdfs:label "wroteReview" .


###  http://xmlns.com/foaf/0.1/knows
<http://xmlns.com/foaf/0.1/knows> rdf:type owl:ObjectProperty ;
                                  rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
                                  rdfs:range <http://xmlns.com/foaf/0.1/Person> .


#################################################################
#    Data properties
#################################################################

###  http://semantics.id/ns/example/film#awardYear
:awardYear rdf:type owl:DatatypeProperty ;
           rdfs:domain :Award ;
           rdfs:range xsd:integer ;
           rdfs:label "awardYear" .


###  http://semantics.id/ns/example/film#budget
:budget rdf:type owl:DatatypeProperty ;
        rdfs:domain :Film ;
        rdfs:range xsd:float ;
        rdfs:label "budget" .


###  http://semantics.id/ns/example/film#dateOfBirth
:dateOfBirth rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
             rdfs:range xsd:date ;
             rdfs:label "dateOfBirth" .


###  http://semantics.id/ns/example/film#duration
:duration rdf:type owl:DatatypeProperty ;
          rdfs:domain :Artwork ;
          rdfs:range xsd:float ;
          rdfs:label "duration" .


###  http://semantics.id/ns/example/film#episodeNumber
:episodeNumber rdf:type owl:DatatypeProperty ;
               rdfs:domain :Episode ;
               rdfs:range xsd:integer ;
               rdfs:label "episodeNumber" .


###  http://semantics.id/ns/example/film#establishedDate
:establishedDate rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :FilmStudio ;
                 rdfs:range xsd:date ;
                 rdfs:label "establishedDate" .


###  http://semantics.id/ns/example/film#fullName
:fullName rdf:type owl:DatatypeProperty ;
          rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
          rdfs:range xsd:string ;
          rdfs:label "fullName" .


###  http://semantics.id/ns/example/film#gender
:gender rdf:type owl:DatatypeProperty ,
                 owl:FunctionalProperty ;
        rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
        rdfs:range xsd:string ;
        rdfs:label "gender" .


###  http://semantics.id/ns/example/film#hasAds
:hasAds rdf:type owl:DatatypeProperty ;
        rdfs:domain :SubscriptionPlan ;
        rdfs:range xsd:boolean ;
        rdfs:label "hasAds" .


###  http://semantics.id/ns/example/film#imdbRating
:imdbRating rdf:type owl:DatatypeProperty ;
            rdfs:domain :Artwork ;
            rdfs:range xsd:decimal ;
            rdfs:label "imdbRating" .


###  http://semantics.id/ns/example/film#maxSimultaneousStreams
:maxSimultaneousStreams rdf:type owl:DatatypeProperty ;
                        rdfs:domain :SubscriptionPlan ;
                        rdfs:range xsd:integer ;
                        rdfs:label "maxSimultaneousStreams" .


###  http://semantics.id/ns/example/film#originalLanguage
:originalLanguage rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Artwork ;
                  rdfs:range xsd:string ;
                  rdfs:label "originalLanguage" .


###  http://semantics.id/ns/example/film#platformURL
:platformURL rdf:type owl:DatatypeProperty ;
             rdfs:domain :StreamingPlatform ;
             rdfs:range xsd:string ;
             rdfs:label "platformURL" .


###  http://semantics.id/ns/example/film#registrationDate
:registrationDate rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Subscriber ;
                  rdfs:range xsd:date ;
                  rdfs:label "registrationDate" .


###  http://semantics.id/ns/example/film#releaseYear
:releaseYear rdf:type owl:DatatypeProperty ;
             rdfs:domain :Film ;
             rdfs:range xsd:integer ;
             rdfs:label "releaseYear" .


###  http://semantics.id/ns/example/film#reviewScore
:reviewScore rdf:type owl:DatatypeProperty ;
             rdfs:domain :Review ;
             rdfs:range xsd:integer ;
             rdfs:label "reviewScore" .


###  http://semantics.id/ns/example/film#seasonNumber
:seasonNumber rdf:type owl:DatatypeProperty ;
              rdfs:domain :Season ;
              rdfs:range xsd:integer ;
              rdfs:label "seasonNumber" .


###  http://semantics.id/ns/example/film#subscriberAge
:subscriberAge rdf:type owl:DatatypeProperty ;
               rdfs:domain :Subscriber ;
               rdfs:range xsd:integer ;
               rdfs:label "subscriberAge" .


###  http://semantics.id/ns/example/film#subscriptionCost
:subscriptionCost rdf:type owl:DatatypeProperty ;
                  rdfs:domain :SubscriptionPlan ;
                  rdfs:range xsd:decimal ;
                  rdfs:label "subscriptionCost" .


###  http://semantics.id/ns/example/film#synopsis
:synopsis rdf:type owl:DatatypeProperty ;
          rdfs:domain :Artwork ;
          rdfs:range xsd:string ;
          rdfs:label "synopsis" .


#################################################################
#    Classes
#################################################################

###  http://semantics.id/ns/example/film#Actor
:Actor rdf:type owl:Class ;
       rdfs:subClassOf :Performer ,
                       <http://xmlns.com/foaf/0.1/Person> ;
       rdfs:label "Actor" .


###  http://semantics.id/ns/example/film#AdFreePlan
:AdFreePlan rdf:type owl:Class ;
            rdfs:subClassOf :SubscriptionPlan .


###  http://semantics.id/ns/example/film#AdSupportedPlan
:AdSupportedPlan rdf:type owl:Class ;
                 rdfs:subClassOf :SubscriptionPlan ;
                 rdfs:label "AdSupportedPlan" .


###  http://semantics.id/ns/example/film#AdultSubscriber
:AdultSubscriber rdf:type owl:Class ;
                 rdfs:subClassOf :Subscriber .


###  http://semantics.id/ns/example/film#AgeRating
:AgeRating rdf:type owl:Class ;
           rdfs:label "AgeRating" .


###  http://semantics.id/ns/example/film#Artwork
:Artwork rdf:type owl:Class ;
         rdfs:label "Artwork" .


###  http://semantics.id/ns/example/film#Award
:Award rdf:type owl:Class ;
       rdfs:label "Award" .


###  http://semantics.id/ns/example/film#AwardWinningArtwork
:AwardWinningArtwork rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( :Artwork
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty :hasAward ;
                                                                  owl:someValuesFrom :Award
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     rdfs:label "AwardWinningArtwork" .


###  http://semantics.id/ns/example/film#BasicPlan
:BasicPlan rdf:type owl:Class ;
           rdfs:subClassOf :SubscriptionPlan ;
           rdfs:label "BasicPlan" .


###  http://semantics.id/ns/example/film#BestComedy
:BestComedy rdf:type owl:Class ;
            rdfs:subClassOf :Emmy ;
            rdfs:label "BestComedy" .


###  http://semantics.id/ns/example/film#BestDrama
:BestDrama rdf:type owl:Class ;
           rdfs:subClassOf :Emmy ;
           rdfs:label "BestDrama" .


###  http://semantics.id/ns/example/film#Cinematographer
:Cinematographer rdf:type owl:Class ;
                 rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ;
                 rdfs:label "Cinematographer" .


###  http://semantics.id/ns/example/film#Composer
:Composer rdf:type owl:Class ;
          rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ;
          rdfs:label "Composer" .


###  http://semantics.id/ns/example/film#CostumeDesigner
:CostumeDesigner rdf:type owl:Class ;
                 rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ;
                 rdfs:label "CostumeDesigner" .


###  http://semantics.id/ns/example/film#Country
:Country rdf:type owl:Class ;
         rdfs:label "Country" .


###  http://semantics.id/ns/example/film#Director
:Director rdf:type owl:Class ;
          rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ;
          rdfs:label "Director" .


###  http://semantics.id/ns/example/film#Editor
:Editor rdf:type owl:Class ;
        rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ;
        rdfs:label "Editor" .


###  http://semantics.id/ns/example/film#Emmy
:Emmy rdf:type owl:Class ;
      rdfs:subClassOf :Award ;
      rdfs:label "Emmy" .


###  http://semantics.id/ns/example/film#EnsembleFilm
:EnsembleFilm rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( :Film
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :hasActor ;
                                                           owl:minQualifiedCardinality "3"^^xsd:nonNegativeInteger ;
                                                           owl:onClass :Actor
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
              rdfs:label "EnsembleFilm" .


###  http://semantics.id/ns/example/film#Episode
:Episode rdf:type owl:Class ;
         rdfs:subClassOf :Artwork ;
         rdfs:label "Episode" .


###  http://semantics.id/ns/example/film#FamilyPlan
:FamilyPlan rdf:type owl:Class ;
            rdfs:subClassOf :SubscriptionPlan ;
            rdfs:label "FamilyPlan" .


###  http://semantics.id/ns/example/film#Film
:Film rdf:type owl:Class ;
      rdfs:subClassOf :Artwork ;
      rdfs:label "Film" .


###  http://semantics.id/ns/example/film#FilmStudio
:FilmStudio rdf:type owl:Class ;
            rdfs:label "FilmStudio" .


###  http://semantics.id/ns/example/film#FullAccessSubscriber
:FullAccessSubscriber rdf:type owl:Class ;
                      rdfs:subClassOf :Subscriber .


###  http://semantics.id/ns/example/film#Genre
:Genre rdf:type owl:Class ;
       rdfs:label "Genre" .


###  http://semantics.id/ns/example/film#GoldenGlobe
:GoldenGlobe rdf:type owl:Class ;
             rdfs:subClassOf :Award ;
             rdfs:label "GoldenGlobe" .


###  http://semantics.id/ns/example/film#Miniseries
:Miniseries rdf:type owl:Class ;
            rdfs:subClassOf :Series ;
            rdfs:label "Miniseries" .


###  http://semantics.id/ns/example/film#Oscar
:Oscar rdf:type owl:Class ;
       rdfs:subClassOf :Award ;
       rdfs:label "Oscar" .


###  http://semantics.id/ns/example/film#PalmeDOr
:PalmeDOr rdf:type owl:Class ;
          rdfs:subClassOf :Award ;
          rdfs:label "PalmeDOr" .


###  http://semantics.id/ns/example/film#Performer
:Performer rdf:type owl:Class ;
           rdfs:label "Performer" .


###  http://semantics.id/ns/example/film#PositiveReview
:PositiveReview rdf:type owl:Class ;
                rdfs:subClassOf :Review .


###  http://semantics.id/ns/example/film#PremiumPlan
:PremiumPlan rdf:type owl:Class ;
             rdfs:subClassOf :SubscriptionPlan ;
             rdfs:label "PremiumPlan" .


###  http://semantics.id/ns/example/film#Producer
:Producer rdf:type owl:Class ;
          rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ;
          rdfs:label "Producer" .


###  http://semantics.id/ns/example/film#Review
:Review rdf:type owl:Class ;
        rdfs:label "Review" .


###  http://semantics.id/ns/example/film#SciFiFilm
:SciFiFilm rdf:type owl:Class ;
           owl:equivalentClass [ owl:intersectionOf ( :Film
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :hasGenre ;
                                                        owl:hasValue :genre_science_fiction
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
           rdfs:label "SciFiFilm" .


###  http://semantics.id/ns/example/film#ScriptWriter
:ScriptWriter rdf:type owl:Class ;
              rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ;
              rdfs:label "ScriptWriter" .


###  http://semantics.id/ns/example/film#Season
:Season rdf:type owl:Class ;
        rdfs:subClassOf :Artwork ;
        rdfs:label "Season" .


###  http://semantics.id/ns/example/film#Series
:Series rdf:type owl:Class ;
        rdfs:subClassOf :Artwork ;
        rdfs:label "Series" .


###  http://semantics.id/ns/example/film#ShortFilm
:ShortFilm rdf:type owl:Class ;
           rdfs:subClassOf :Film ;
           rdfs:label "ShortFilm" .


###  http://semantics.id/ns/example/film#Soundtrack
:Soundtrack rdf:type owl:Class ;
            rdfs:subClassOf :Artwork ;
            rdfs:label "Soundtrack" .


###  http://semantics.id/ns/example/film#StreamingPlatform
:StreamingPlatform rdf:type owl:Class ;
                   rdfs:label "StreamingPlatform" .


###  http://semantics.id/ns/example/film#StudentPlan
:StudentPlan rdf:type owl:Class ;
             rdfs:subClassOf :SubscriptionPlan ;
