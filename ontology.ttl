                                        rdfs:label "Son of a Gun" .

<http://semantics.id/ns/example#film_3> rdf:type owl:NamedIndividual , :Film ;
                                        :hasActor <http://semantics.id/ns/example#dan_stevens> , <http://semantics.id/ns/example#emma_watson> , <http://semantics.id/ns/example#ewan_mcgregor> ;
                                        :hasDirector <http://semantics.id/ns/example#bill_condon> ;
                                        :hasFilmStudio <http://semantics.id/ns/example#WaltDisneyPictures> ;
