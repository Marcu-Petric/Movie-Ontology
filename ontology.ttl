:hans_zimmer rdf:type owl:NamedIndividual , :Composer ; :fullName "Hans Zimmer" .
:kyle_maclachlan rdf:type owl:NamedIndividual , :Actor ; :dateOfBirth "1959-02-22"^^xsd:date ; :fullName "Kyle Merritt MacLachlan" ; :gender "male" .
:zendaya rdf:type owl:NamedIndividual , :Actor ; :dateOfBirth "1996-09-01"^^xsd:date ; :fullName "Zendaya Maree Stoermer Coleman" ; :gender "female" .