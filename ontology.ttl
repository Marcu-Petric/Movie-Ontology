#    Rules
#################################################################

:s rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:e1 rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:season rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:e2 rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:f rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:a1 rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:g rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:film rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:r rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:score rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:p rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:platform rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:c rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:series rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:a rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:b rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:x rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:a2 rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:age rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "If subscriber A is a friend of B, and B likes artwork X, and A has not watched X, then recommend X to A." ;
   rdfs:label "recommendToRule" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :Subscriber ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :a
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> :friendOf ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> :a ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> :b
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
